{
  "name": "trace2",
  "version": "1.0.0",
  "description": "A simple CAP project.",
  "dependencies": {
    "@odatano/core": "^1.9.0",
    "@sap/cds": "^9",
    "express": "^4"
  },
  "devDependencies": {
    "@cap-js/cds-test": "^0.4.1",
    "@cap-js/cds-typer": "^0.38.0",
    "@cap-js/cds-types": "^0.15.0",
    "@cap-js/sqlite": "^2",
    "@sap/cds-dk": "^9.4.3",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.19.7",
    "jest": "^29.6.1",
    "ts-jest": "^29.4.5",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "start": "cds-serve",
    "cds:types": "cds-typer \"*\" --outputDirectory @cds-models",
    "typecheck": "tsc --noEmit",
    "db:deploy": "cds deploy",
    "pretest": "npm run cds:types && npm run db:deploy",
    "test": "jest --runInBand",
    "test:unit": "jest --runInBand --testPathPattern=test/unit",
    "test:integration": "jest --runInBand --testPathPattern=test/integration",
    "test:coverage": "jest --runInBand --coverage",
    "test:ci": "jest --runInBand",
    "test:ci:coverage": "jest --runInBand --coverage"
  },
  "cds": {
    "requires": {
      "[development]": {
        "auth": {
          "kind": "dummy"
        }
      },
      "db": {
        "kind": "sqlite",
        "credentials": {
          "url": "db.sqlite"
        }
      },
      "odatano-core": {
        "network": "preview",
        "backends": [
          "blockfrost",
          "koios"
        ],
        "txBuilders": [
          "buildooor"
        ]
      }
    }
  },
  "private": true
}
