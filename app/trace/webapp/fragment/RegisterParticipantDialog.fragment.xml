<core:FragmentDefinition
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  xmlns:f="sap.ui.layout.form">

  <Dialog id="registerParticipantDialog" title="Register as Participant" contentWidth="420px">
    <content>
      <MessageStrip
        text="Minting a registration NFT to your wallet proves your identity on the Cardano blockchain. This requires a small transaction fee (~2 ADA)."
        type="Information" showIcon="true"
        class="sapUiSmallMarginBottom"/>

      <f:SimpleForm
        editable="true"
        layout="ResponsiveGridLayout"
        labelSpanXL="4" labelSpanL="4" labelSpanM="4"
        emptySpanXL="0" emptySpanL="0" emptySpanM="0"
        columnsXL="1" columnsL="1" columnsM="1">

        <Label text="Name" required="true"/>
        <Input id="registerName" value="{registerForm>/name}" placeholder="Your name or organization"/>

        <Label text="Role" required="true"/>
        <Select id="registerRole" selectedKey="{registerForm>/role}">
          <core:Item key="Manufacturer" text="Manufacturer"/>
          <core:Item key="Distributor" text="Distributor"/>
          <core:Item key="Pharmacy" text="Pharmacy"/>
          <core:Item key="Regulator" text="Regulator"/>
        </Select>

        <Label text="Wallet Address"/>
        <Text text="{registerForm>/walletAddress}" wrapping="true"/>

        <Label text="Verification Key Hash"/>
        <Text text="{registerForm>/walletVkh}"/>
      </f:SimpleForm>
    </content>
    <beginButton>
      <Button text="Register" type="Emphasized" press=".onRegisterConfirm"/>
    </beginButton>
    <endButton>
      <Button text="Cancel" press=".onRegisterCancel"/>
    </endButton>
  </Dialog>

</core:FragmentDefinition>
